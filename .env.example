# ============================================================================
# Infrastructure Deployment Generator — Environment Configuration Template
# ============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to source control.
# ============================================================================

# --- Azure Service Principal ---
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-service-principal-app-id
AZURE_CLIENT_SECRET=your-service-principal-secret
AZURE_SUBSCRIPTION_ID=your-subscription-id

# --- Azure Resource Groups ---
# Named RGs — use any AZURE_RG_* prefix (e.g., AZURE_RG_COMPUTE, AZURE_RG_NETWORK)
AZURE_RG_COMPUTE=rg-name-compute
AZURE_RG_NETWORK=rg-name-network

# --- Permitted Resource Groups (comma-separated) ---
# Only these RGs can be queried or modified by the application
PERMITTED_RESOURCE_GROUPS=rg-name-compute,rg-name-network

# --- Azure Networking ---
AZURE_VNET_PRIMARY=vnet-name-primary
AZURE_SUBNET_PRIMARY=subnet-name-primary
AZURE_VNET_SECONDARY=vnet-name-secondary
AZURE_SUBNET_SECONDARY=subnet-name-secondary
AZURE_BASTION_NAME=bastion-name

# --- Cosmos DB ---
COSMOS_DB_ENDPOINT=https://your-cosmos-account.documents.azure.com:443/
COSMOS_DB_KEY=your-cosmos-primary-key
COSMOS_DB_DATABASE=infDepGen

# --- Claude AI (Anthropic API) ---
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# --- Authentication ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-secure-password

# --- App Service ---
APP_PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Environment Identifier ---
APP_ENVIRONMENT=lab

# --- Server Specs Directory (optional, defaults to docs/server-specs/) ---
# SERVER_SPECS_DIR=/path/to/server-specs
